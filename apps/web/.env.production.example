# Web — PRODUCTION env template.
# Copy to `.env.production` and fill in real values. The copy is gitignored.
#   cp apps/web/.env.production.example apps/web/.env.production
#
# Vite loads .env.production automatically in production builds
# (`npm run build`). Values are baked into the static bundle.

VITE_API_URL=https://api.yourdomain.com/api/v1
VITE_SUPABASE_URL=https://your-prod-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-prod-supabase-anon-key
VITE_UI_PREVIEW=false

# Shown on the Login page as a mailto link so staff who can't sign in
# can reach the property administrator without leaving the browser.
VITE_ADMIN_CONTACT_EMAIL=admin@yourdomain.com
