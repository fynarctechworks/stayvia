# Web — DEVELOPMENT env template.
# Copy to `.env.development` and fill in real values. The copy is gitignored.
#   cp apps/web/.env.development.example apps/web/.env.development
#
# Vite loads .env.development automatically in dev mode (`npm run dev`).

VITE_API_URL=http://localhost:3001/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_UI_PREVIEW=false

# Shown on the Login page as a mailto link so staff who can't sign in
# can reach the property administrator without leaving the browser.
VITE_ADMIN_CONTACT_EMAIL=admin@yourdomain.com
