# ============ FRONTEND (apps/web/.env) ============
VITE_API_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ============ API (apps/api/.env) ============
PORT=3000
NODE_ENV=development

# Supabase
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=from_supabase_project_settings

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://YOUR.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
UPSTASH_REDIS_URL=rediss://default:PASS@YOUR.upstash.io:6379

# Encryption (32-byte hex string for AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# CORS
FRONTEND_URL=http://localhost:5173

# Initial admin (used by seed script)
SEED_ADMIN_EMAIL=admin@hoteldesk.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Hotel Owner
